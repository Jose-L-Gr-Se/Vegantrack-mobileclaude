# Copia este archivo a .env y rellena los valores reales.
# Las variables EXPO_PUBLIC_* se inyectan en el bundle JS (no pongas secretos de servidor aquí).

# Supabase (mismo proyecto que la PWA Vegetrack)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Base de la PWA / API Vercel (checkout Stripe se abre en el navegador)
EXPO_PUBLIC_WEB_BASE_URL=https://vegantrack.app
