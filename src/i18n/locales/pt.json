    },
    "eco": {
      "title": "Eco-Score",
      "intro": "Estima o impacto ambiental de um produto ao longo do seu ciclo de vida: cultivo dos ingredientes, transporte, embalagem e origem. Quanto mais próximo de A, menor a pegada estimada.",
      "a": "pegada ambiental muito baixa",
      "b": "baixa",
      "c": "média",
      "d": "alta",
      "e": "muito alta",
      "tip": "Uma dieta à base de plantas geralmente pontua melhor no Eco-Score do que opções de origem animal. É uma orientação, não um veredicto."
    },
    "nova": {
      "title": "NOVA · nível de processamento",
      "intro": "Classifica os alimentos pelo grau de processamento industrial, não pelas calorias. Um grupo NOVA alto não significa \"tóxico\" — apenas que o produto passou por mais transformações e aditivos.",
      "1": "não processado (frutas, leguminosas secas…)",
      "2": "minimamente processado (azeite, sal…)",
      "3": "processado (conservas, pão…)",
      "4": "ultraprocessado (com aditivos e formulações)",
      "tip": "Uma dieta consciente tende a usar 1 e 2 como base, sem demonizar os ocasionais 3 e 4 que se encaixam no seu dia."
    }
