  "scoreInfo": {
    "scaleHeader": "Die Skala, einfach erklärt",
    "tipHeader": "Zu beachten",
    "nutri": {
      "title": "Nutri-Score",
      "intro": "Fasst die allgemeine Nährwertqualität eines Produkts mit einem Buchstaben von A bis E zusammen. Kalorien, Zucker, gesättigte Fettsäuren und Salz werden negativ bewertet; Ballaststoffe, Protein, Obst und Gemüse positiv.",
      "a": "bestes Nährwertprofil",
      "b": "gut",
      "c": "durchschnittlich",
      "d": "verbesserungswürdig",
      "e": "schlechtestes Profil in seiner Kategorie",
      "tip": "Vergleiche Produkte innerhalb derselben Kategorie (z. B. Joghurt mit Joghurt). Ein E bedeutet nicht automatisch \"schlecht\" — es hilft dir, die beste Wahl unter mehreren Optionen zu treffen."
    },
    "eco": {
      "title": "Eco-Score",
      "intro": "Schätzt die Umweltauswirkung eines Produkts über seinen Lebenszyklus: Anbau der Zutaten, Transport, Verpackung und Herkunft. Je näher an A, desto geringer der geschätzte Fußabdruck.",
      "a": "sehr geringer ökologischer Fußabdruck",
      "b": "gering",
      "c": "mittel",
      "d": "hoch",
      "e": "sehr hoch",
      "tip": "Pflanzenbasierte Ernährung schneidet beim Eco-Score in der Regel besser ab als tierische Optionen. Es ist eine Orientierung, kein Urteil."
    },
    "nova": {
      "title": "NOVA · Verarbeitungsgrad",
      "intro": "Klassifiziert Lebensmittel nach dem Grad ihrer industriellen Verarbeitung, nicht nach Kalorien. Eine hohe NOVA-Gruppe bedeutet nicht \"giftig\" — nur, dass das Produkt mehr Transformationen und Zusatzstoffe durchlaufen hat.",
      "1": "unverarbeitet (Obst, getrocknete Hülsenfrüchte…)",
      "2": "minimal verarbeitet (Öl, Salz…)",
      "3": "verarbeitet (Konserven, Brot…)",
      "4": "hochverarbeitet (mit Zusatzstoffen und Formulierungen)",
      "tip": "Eine bewusste Ernährung tendiert zu 1 und 2 als Basis, ohne gelegentliche 3 und 4 zu verteufeln."
    }
  },
