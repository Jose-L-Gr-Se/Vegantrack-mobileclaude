  "scoreInfo": {
    "scaleHeader": "The scale, simply",
    "tipHeader": "Keep in mind",
    "nutri": {
      "title": "Nutri-Score",
      "intro": "Summarises the overall nutritional quality of a product with a letter from A to E. It weighs calories, sugars, saturated fat and salt negatively; fibre, protein, fruit and vegetables positively.",
      "a": "best nutritional profile",
      "b": "good",
      "c": "average",
      "d": "below average",
      "e": "worst profile in its category",
      "tip": "Compare products within the same category (e.g. yoghurts with yoghurts). An E rating doesn't make something \"bad\" — it helps you choose the best option among several."
    },
    "eco": {
      "title": "Eco-Score",
      "intro": "Estimates the environmental impact of a product across its lifecycle: how ingredients are grown, transport, packaging and origin. The closer to A, the lower the estimated footprint.",
      "a": "very low environmental footprint",
      "b": "low",
      "c": "medium",
      "d": "high",
      "e": "very high",
      "tip": "Plant-based diets generally score better on eco than animal-based options. It's a guide, not a verdict."
    },
    "nova": {
      "title": "NOVA · processing level",
      "intro": "Classifies foods by how much industrial processing they have undergone, not by calories. A high NOVA group doesn't mean \"toxic\" — just that the product has gone through more transformations and additives.",
      "1": "unprocessed (fruit, dried legumes…)",
      "2": "minimally processed (oil, salt…)",
      "3": "processed (canned goods, bread…)",
      "4": "ultra-processed (with additives and formulations)",
      "tip": "A mindful diet tends to use 1s and 2s as the base, without demonising the occasional 3 or 4 that fits your day."
    }
  },
