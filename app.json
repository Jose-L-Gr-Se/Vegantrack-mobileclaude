{
  "expo": {
    "name": "VeganTrack",
    "slug": "vegantrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vegantrack",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vegantrack.app"
    },
    "android": {
      "package": "com.vegantrack.app",
      "compileSdkVersion": 35,
      "targetSdkVersion": 34,
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "backgroundColor": "#2f5d41",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "vegantrack.app", "pathPrefix": "/" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#2f5d41"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "VeganTrack usa la cámara para escanear códigos de barras de alimentos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "VeganTrack usa tus fotos para analizar platos y calcular sus nutrientes.",
          "cameraPermission": "VeganTrack usa la cámara para fotografiar tus platos y analizarlos con IA."
        }
      ]
    ]
  }
}
